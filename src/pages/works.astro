---
import Base from '../layouts/Base.astro';
import CtaSection from '../components/CtaSection.astro';
---

<Base
  title="制作実績"
  description="まちのAI屋さんのWeb制作実績。長崎の中小企業・個人事業主のホームページ制作をお手伝いしています。"
>
  <div class="page-header">
    <div class="container">
      <h1>制作実績</h1>
      <p>長崎の事業者さまのホームページをお手伝いしています</p>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <div class="works">
        <div class="work-card">
          <div class="work-card__frame">
            <img src="/assets/images/works-ohama.png" alt="大濱畳店様 ホームページ制作実績" loading="lazy" />
          </div>
          <div class="work-card__body">
            <h3>大濱畳店 様</h3>
            <!-- TODO: 公開URL確定後に「サイトを見る」リンクを追加 -->
            <!-- TODO: 掲載許可済みの一言コメント取得後に work-card__voice を追加 -->
          </div>
        </div>
        <div class="work-card">
          <div class="work-card__frame">
            <img src="/assets/images/works-nakahira.png" alt="中平個人タクシー様 ホームページ制作実績" loading="lazy" />
          </div>
          <div class="work-card__body">
            <h3>中平個人タクシー 様</h3>
          </div>
        </div>
      </div>
      <!-- 将来拡張: インタビュー形式の詳しい事例記事はコラム（caseカテゴリ）に追加していく -->
    </div>
  </section>

  <CtaSection />
</Base>
